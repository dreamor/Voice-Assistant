# 敏感配置示例 - 复制为 .env 并填入真实值
#
#   cp .env.example .env && $EDITOR .env
#
# 至少需要填入一个 LLM provider 的 key 与一个 ASR key。
# 默认 LLM 走 dashscope provider；ASR 默认走 DashScope Paraformer。
# DashScope 同一把 key 通常可同时用于 ASR 与 LLM。

# === 必填 ===
# ASR (DashScope Paraformer，控制台：https://dashscope.console.aliyun.com/)
ASR_API_KEY=your-dashscope-key-here

# LLM Provider key（按当前活跃 provider 选填一个；默认 dashscope）
DASHSCOPE_API_KEY=your-dashscope-key-here

# === 可选：其它内置 Provider（在 ⚙ 配置页切换时使用）===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# === 可选：自定义 Provider ===
# 通过 ⚙ → 添加 Provider 后，会按 {PROVIDER_ID}_API_KEY 命名约定读取此处。
# 示例：
# MY_OLLAMA_API_KEY=ollama-local
