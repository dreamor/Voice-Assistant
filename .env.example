# 敏感配置示例 - 复制为 .env 并填入真实值
#
#   cp .env.example .env && $EDITOR .env

# === ASR（语音识别）===
# DashScope Paraformer，控制台：https://dashscope.console.aliyun.com/
ASR_API_KEY=your-dashscope-key-here

# === LLM Provider 选择 ===
# 下方 providers 按 config.yaml 的顺序自动编号：
#   1 = dashscope, 2 = openai, 3 = anthropic, 4 = deepseek, 5+ = 自定义
# 把序号写到 LLM_API_KEY，决定当前活跃 provider（默认 1）
LLM_API_KEY=1

# === Provider Keys（用哪个 provider 就填对应一行）===
DASHSCOPE_API_KEY=your-dashscope-key-here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# === 自定义 Provider ===
# ⚙ → 添加 Provider 后，按 {PROVIDER_ID}_API_KEY 命名约定读取此处。
# 示例：
# MY_OLLAMA_API_KEY=ollama-local
