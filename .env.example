# 敏感配置示例 - 复制为 .env 并填入真实值
#
#   cp .env.example .env && $EDITOR .env
#
# 至少需要填入一个 LLM 与一个 ASR 的 API Key。
# 默认 LLM 走 dashscope provider（与 ASR 共用同一把 DashScope Key）。

# === 必填 ===
# ASR (DashScope Paraformer，控制台：https://dashscope.console.aliyun.com/)
ASR_API_KEY=your-asr-api-key-here

# LLM 主 Key（dashscope provider 默认读取这个；其它 provider 见下方）
LLM_API_KEY=your-llm-api-key-here

# === 可选：内置 Provider（在 ⚙ 配置页切换时使用）===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# === 可选：自定义 Provider ===
# 通过 ⚙ → 添加 Provider 后，会按 {PROVIDER_ID}_API_KEY 的命名约定读取此处。
# 示例：
# MY_OLLAMA_API_KEY=ollama-local
